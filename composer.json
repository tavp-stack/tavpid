{
    "name": "tavp/tavpid",
    "description": "TAVPid — OTP-first authentication for TAVP (email/SMS/WhatsApp OTP, JWT, OAuth, TOTP).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Tavp\\Tavpid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tavp\\Tavpid\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
