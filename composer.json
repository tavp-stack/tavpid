{
    "name": "tavp/tavpid",
    "description": "TAVPid — OTP-first authentication for TAVP (email/SMS/WhatsApp OTP, JWT, session, RBAC).",
    "type": "library",
    "license": "MIT",
    "keywords": ["tavp", "auth", "otp", "jwt", "rbac", "session"],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Tavp\\Tavpid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tavp\\Tavpid\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "support": {
        "issues": "https://github.com/tavp-stack/tavpid/issues",
        "source": "https://github.com/tavp-stack/tavpid"
    }
}
